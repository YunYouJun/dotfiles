{
  "name": "@yunyoujun/dotfiles-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r run build",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm test && pnpm run build",
    "dev": "pnpm -r run dev",
    "lint": "eslint .",
    "release": "bumpp -r && pnpm -r run build",
    "sync": "dotfiles sync",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "bumpp": "^11.0.1",
    "changelogithub": "^14.0.0",
    "eslint": "^10.3.0",
    "typescript": "^5.9.3"
  }
}
