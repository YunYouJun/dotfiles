{
  "editor.wordWrap": "on",
  "editor.tabSize": 2,
  "editor.fontFamily": "Fira Code, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "explorer.autoReveal": true,
  "explorer.autoRevealExclude": {
    "**/node_modules": false,
    "**/bower_components": true
  },
  // Auto fix
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.stylelint": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.list.smoothScrolling": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter.notebook.ipynb"
  },
  "workbench.editor.wrapTabs": true,
  "workbench.startupEditor": "none",
  "[python]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnType": true
  },
  // "php.validate.executablePath": "C:\\xampp\\php\\php.exe",
  "files.exclude": {
    // "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.simpleDialog.enable": true,
  "emmet.includeLanguages": {
    "plaintext": "html",
    "vue-html": "html",
    "javascript": "javascriptreact",
    "markdown": "html",
    "php": "html",
    "wxml": "html",
    "axml": "xml"
  },
  "gitlens.defaultDateStyle": "absolute",
  "gitlens.remotes": [
    {
      "domain": "code.alipay.com",
      "type": "Custom",
      "name": "AntCode",
      "protocol": "https",
      "urls": {
        "repository": "https://code.alipay.com/${repo}",
        "branches": "https://code.alipay.com/${repo}/branches",
        "branch": "https://code.alipay.com/${repo}/tree/${branch}",
        "commit": "https://code.alipay.com/${repo}/commit/${id}",
        "file": "https://code.alipay.com/${repo}/blob/${branch}/${file}",
        "fileInBranch": "https://code.alipay.com/${repo}/blob/${branch}/${file}",
        "fileInCommit": "https://code.alipay.com/${repo}/blob/${id}/${file}",
        "fileLine": "https://code.alipay.com/${repo}/blob/${branch}/${file}#L${line}",
        "fileRange": "https://code.alipay.com/${repo}/blob/${branch}/${file}#L${line}-${endLine}"
      }
    },
    {
      "domain": "git.woa.com",
      "type": "Custom",
      "name": "Tencent",
      "protocol": "https",
      "urls": {
        "repository": "https://git.woa.com/${repo}",
        "branches": "https://git.woa.com/${repo}/branches",
        "branch": "https://git.woa.com/${repo}/tree/${branch}",
        "commit": "https://git.woa.com/${repo}/commit/${id}",
        "file": "https://git.woa.com/${repo}/tree/${branch}/${file}",
        "fileInBranch": "https://git.woa.com/${repo}/blob/${branch}/${file}",
        "fileInCommit": "https://git.woa.com/${repo}/blob/${id}/${file}",
        "fileLine": "https://git.woa.com/${repo}/blob/${branch}/${file}#L${line}",
        "fileRange": "https://git.woa.com/${repo}/blob/${branch}/${file}#L${line}-${endLine}"
      }
    }
  ],
  "explorer.confirmDelete": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "terminal.integrated.fontFamily": "MesloLGS NF, Source Code Pro, monospace",
  "terminal.integrated.windowsEnableConpty": true,
  "explorer.confirmDragAndDrop": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.autoClosingBrackets": "languageDefined"
  },
  "[typescriptreact]": {
    "editor.autoClosingBrackets": "languageDefined",
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "markdownlint.config": {
    "MD013": false,
    "MD026": false,
    "MD028": false,
    "MD033": false
  },
  "[markdown]": {
    "editor.tabCompletion": "onlySnippets",
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.autoClosingBrackets": "languageDefined"
  },
  "latex-workshop.view.pdf.viewer": "browser",
  "[vue]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[yaml]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[latex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop"
  },
  "latex-workshop.bind.altKeymap.enabled": true,
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "go.formatTool": "goimports",
  "go.useLanguageServer": true,
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "python": "python3 -u"
  },
  "python.linting.pylintArgs": [
    "--unsafe-load-any-extension=y"
  ],
  "git.autofetch": true,
  "[stylus]": {
    "editor.defaultFormatter": "thisismanta.stylus-supremacy"
  },
  "i18n-ally.displayLanguage": "zh-CN",
  "security.workspace.trust.untrustedFiles": "open",
  "redhat.telemetry.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
    "typescript": true
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "search.followSymlinks": false,
  "search.exclude": {
    "**/.git": true,
    "**/.nuxt": true,
    "**/.output": true,
    "**/.pnpm": true,
    "**/.yarn": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/logs": true,
    "**/node_modules": true,
    "**/out/**": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/tmp": true,
    "**/yarn.lock": true
  },
