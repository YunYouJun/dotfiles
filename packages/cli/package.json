{
  "name": "@yunyoujun/dotfiles",
  "type": "module",
  "version": "0.1.0",
  "description": "CLI tool for syncing dotfiles",
  "author": "YunYouJun <me@yunyoujun.cn>",
  "license": "MIT",
  "homepage": "https://github.com/YunYouJun/dotfiles",
  "repository": {
    "type": "git",
    "url": "https://github.com/YunYouJun/dotfiles",
    "directory": "packages/cli"
  },
  "keywords": [
    "dotfiles",
    "cli",
    "sync"
  ],
  "bin": {
    "dotfiles": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "cac": "^7.0.0",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
